# /etc/molodost48/api.env — sourced by systemd unit
# Permissions: 0640 root:molodost
NODE_ENV=production
PORT=3000
HOST=127.0.0.1
LOG_LEVEL=info

DATABASE_URL=postgresql://molodost:CHANGE_ME@127.0.0.1:5432/molodost48?schema=public

JWT_SECRET=CHANGE_ME_64_HEX
COOKIE_DOMAIN=molodost48.ru
COOKIE_SECURE=true

MEDIA_ROOT=/var/lib/molodost48/uploads
MEDIA_PUBLIC_BASE=/media
MAX_UPLOAD_BYTES=10485760

BACKUP_DIR=/var/lib/molodost48/backups
BACKUP_RETENTION_DAYS=7

CORS_ORIGINS=https://www.molodost48.ru,https://molodost48.ru