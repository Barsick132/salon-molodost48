// Prisma schema for molodost48.
//
// Conventions:
// - All tables have `id` (cuid), `createdAt`, `updatedAt`.
// - Soft delete via `isActive` / `isApproved` flags where appropriate.
// - For full DB initialisation run: pnpm db:migrate && pnpm db:seed.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Site singleton + navigation
// ============================================================

model SiteSettings {
  id             String  @id @default("singleton")
  brandName      String  @default("Молодость")
  brandTagline   String  @default("Салон красоты бизнес-класса")
  logoMediaId    String?
  faviconMediaId String?

  address String  @default("г. Липецк, ул. Пушкина 4, пом. 6")
  phones  String[] @default(["8 (904) 219-19-99", "8 (474) 271-93-80"])
  email   String  @default("support@molodost48.ru")
  // Single-line working hours, free-form text. Examples:
  //   "пн-пт 10:00–20:00, сб-вс выходной"
  //   "Ежедневно 10:00–20:00"
  //   "пн-сб 09:00–21:00, вс — выходной"
  // The admin form shows a textarea with these examples as placeholders.
  workingHoursText String @default("пн-пт 10:00–20:00, сб-вс выходной")
  socials          Json   @default("{}")

  // ----- Map / location -----
  // mapProvider: "yandex" (default — iframe generator by address) | "custom" | "hidden"
  mapProvider  String  @default("yandex")
  // iframe URL — used when mapProvider = "custom", overrides the
  // Yandex generator. Empty when mapProvider = "yandex".
  mapIframeUrl String  @default("")
  // Zoom for the auto-generated Yandex iframe.
  mapZoom      Int     @default(15)
  // When true, the map block is not rendered on the public contacts
  // page at all (the section just shows the address as text).
  mapHidden    Boolean @default(false)

  // ----- Centralised "Записаться онлайн" CTA -----
  // One source of truth for the booking button. The admin CtaPage
  // edits these. Public surfaces (toolbar, banner, cta-strip) opt
  // in via the showIn* flags below.
  ctaLabel          String  @default("Записаться онлайн")
  ctaUrl            String  @default("https://dikidi.ru/#widget=212727")
  ctaShowInToolbar  Boolean @default(true)
  ctaShowInBanner   Boolean @default(true)
  ctaShowInCtaStrip Boolean @default(true)

  // ----- Page / section visibility -----
  // The only pages/sections we currently render. Future pages
  // (gallery, masters, reviews, etc.) are not built and have no
  // navigation; their flags were removed.
  servicesPageEnabled        Boolean @default(true)
  homeServicesSectionEnabled Boolean @default(true)
  servicesInNavEnabled       Boolean @default(true)

  seoTitle       String  @default("Молодость — салон красоты в Липецке")
  seoDescription String  @default("Салон красоты бизнес-класса в Липецке с 2013 года. Стрижки, окрашивание, уход, маникюр, педикюр, косметология. Запись онлайн через Dikidi.")
  seoOgImageId   String?
  robotsTxt      String  @default("User-agent: *\nAllow: /")

  accentColor          String  @default("#E11D48")
  fontFamily           String  @default("Inter")
  enableStructuredData Boolean @default(true)

  logoUrl    String @default("")
  faviconUrl String @default("")

  updatedAt DateTime @updatedAt
}

model NavItem {
  id         String    @id @default(cuid())
  label      String
  href       String
  order      Int       @default(0)
  isExternal Boolean   @default(false)
  parentId   String?
  parent     NavItem?  @relation("NavTree", fields: [parentId], references: [id])
  children   NavItem[] @relation("NavTree")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

// ============================================================
// Landing blocks (toggle + drag-and-drop order)
// ============================================================

model Block {
  id        String   @id @default(cuid())
  type      String // banner (was hero) | stats | advantages | cta-strip
  enabled   Boolean  @default(true)
  order     Int      @default(0)
  payload   Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
}

// ============================================================
// Service catalog
// ============================================================

model ServiceCategory {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  icon        String    @default("")
  description String    @default("")
  order       Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  services    Service[]

  @@index([order])
}

model Service {
  id              String          @id @default(cuid())
  categoryId      String
  category        ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name            String
  description     String          @default("")
  priceFrom       Int?
  priceTo         Int?
  durationMinutes Int?
  isPopular       Boolean         @default(false)
  isActive        Boolean         @default(true)
  order           Int             @default(0)
  externalId      String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([categoryId, externalId])
  @@index([categoryId, order])
  @@index([isActive, isPopular])
}

// ============================================================
// Masters (table kept — feature deferred)
// ============================================================

model Master {
  id                String   @id @default(cuid())
  name              String
  role              String   @default("")
  bio               String   @default("")
  experienceYears   Int?
  avatarMediaId     String?
  portfolioMediaIds String[] @default([])
  categoryIds       String[] @default([])
  order             Int      @default(0)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([order, isActive])
}

// ============================================================
// Promotions (table kept — feature deferred)
// ============================================================

model Promotion {
  id              String    @id @default(cuid())
  title           String
  description     String    @default("")
  coverMediaId    String?
  serviceIds      String[]  @default([])
  discountPercent Int?
  discountFixed   Int?
  validFrom       DateTime?
  validUntil      DateTime?
  isActive        Boolean   @default(true)
  order           Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([isActive, validUntil])
}

// ============================================================
// Gallery (table kept — feature deferred)
// ============================================================

model GalleryCategory {
  id        String        @id @default(cuid())
  name      String
  order     Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  items     GalleryItem[]
}

model GalleryItem {
  id         String          @id @default(cuid())
  categoryId String
  category   GalleryCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  mediaId    String
  caption    String          @default("")
  masterId   String?
  order      Int             @default(0)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([categoryId, order])
}

// ============================================================
// Rooms (table kept — feature deferred)
// ============================================================

model Room {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  mediaIds    String[] @default([])
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([order])
}

// ============================================================
// Reviews (table kept — feature deferred)
// ============================================================

model Review {
  id            String   @id @default(cuid())
  authorName    String
  rating        Int
  text          String
  source        String   @default("")
  avatarMediaId String?
  publishedAt   DateTime @default(now())
  isApproved    Boolean   @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isApproved, publishedAt])
}

// ============================================================
// FAQ (table kept — feature deferred)
// ============================================================

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String   @default("")
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
}

// ============================================================
// Vacancies (table kept — feature deferred)
// ============================================================

model Vacancy {
  id           String   @id @default(cuid())
  title        String
  description  String   @default("")
  requirements String   @default("")
  salaryFrom   Int?
  salaryTo     Int?
  contactEmail String?
  contactPhone String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive, createdAt])
}

// ============================================================
// Static pages
// ============================================================

model StaticPage {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  body        String   @default("")
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================================
// Media library
// ============================================================

model Media {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  mimeType     String
  sizeBytes    Int
  width        Int?
  height       Int?
  alt          String   @default("")
  storagePath  String
  createdAt    DateTime @default(now())

  @@index([createdAt])
}

// ============================================================
// Admin auth
// ============================================================

model AdminUser {
  id                  String               @id @default(cuid())
  email               String               @unique
  displayName         String               @default("")
  passwordHash        String
  role                String               @default("admin")
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  lastLoginAt         DateTime?
  sessions            AdminSession[]
  passwordResetTokens PasswordResetToken[]
  emailChangeRequests EmailChangeRequest[]
}

model AdminSession {
  id        String    @id @default(cuid())
  userId    String
  user      AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  ipAddress String?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model EmailChangeRequest {
  id        String    @id @default(cuid())
  userId    String
  user      AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  newEmail  String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// ============================================================
// Integrations (kept for future use, not surfaced in admin UI)
// ============================================================

model IntegrationConfig {
  id             String    @id
  type           String
  enabled        Boolean   @default(false)
  config         Json      @default("{}")
  credentials    Json?
  lastSyncAt     DateTime?
  lastSyncStatus String?
  updatedAt      DateTime  @updatedAt
  updatedBy      String?

  @@index([type])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  diff      Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([entity, entityId])
}
