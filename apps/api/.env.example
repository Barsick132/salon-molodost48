# --- Server ---
NODE_ENV=production
PORT=3000
HOST=127.0.0.1
LOG_LEVEL=info

# --- Database ---
DATABASE_URL=postgresql://molodost:CHANGE_ME@127.0.0.1:5432/molodost48?schema=public

# --- Auth ---
# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_64_HEX
# Cookie domain — leave empty in dev, set to .molodost48.ru in prod
COOKIE_DOMAIN=
COOKIE_SECURE=false

# --- Bootstrap admin (used only by prisma/seed.ts on first run) ---
ADMIN_BOOTSTRAP_EMAIL=admin@molodost48.ru
ADMIN_BOOTSTRAP_PASSWORD=CHANGE_ME_STRONG
ADMIN_BOOTSTRAP_NAME=Администратор

# --- Media ---
MEDIA_ROOT=/var/lib/molodost48/uploads
MEDIA_PUBLIC_BASE=/media
MAX_UPLOAD_BYTES=10485760

# --- CORS (comma-separated origins, leave empty to disable) ---
CORS_ORIGINS=

# --- Backup ---
BACKUP_DIR=/var/lib/molodost48/backups
BACKUP_RETENTION_DAYS=7